# Dependencies
node_modules/

# OS / editor junk
.DS_Store
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# Temporary test projects (our dogfooding harnesses)
omakase-dogfood-*
/tmp/omakase-*

# Local harness test installs the developer creates *at the root* of this (or any) project
# when testing the installer. Anchored with leading / so they don't accidentally ignore
# the bundled dist/<harness>/.xxx/ trees that we intentionally commit.
 /.cursor/
 /.claude/
 /.agents/

# Environment / secrets
.env
.env.local
*.pem
*.key

# dist/ and .omakaseagent/ are deliberately NOT ignored.
/.agents/skills/omakase
/.codex/agents
/.cursor
/.grok
/.opencode/agents
